{
  "name": "tanstack-mcp",
  "version": "1.0.0",
  "description": "MCP server that wraps the TanStack CLI for programmatic access to docs, libraries, add-ons, and project scaffolding",
  "type": "module",
  "bin": {
    "tanstack-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "tanstack",
    "mcp",
    "model-context-protocol",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3"
  }
}
